---
import { MapPinIcon } from "../ui/map-pin-icon.jsx";
---

<section id="map" class="w-full">
  <div class="w-full h-[400px] md:h-[500px] relative bg-bg-soft">
    <iframe
      src="https://yandex.ru/map-widget/v1/?ll=47.89,56.63&z=12&l=map&pt=47.89,56.63,pm2rdm"
      width="100%"
      height="100%"
      style="border: 0"
      allowfullscreen
      loading="eager"
      title="Карта — место проведения свадьбы"
      class="block"
    ></iframe>
  </div>
  <div class="text-center py-4 px-6">
    <a
      href="https://yandex.ru/maps/?text=ресторан+Savory+House+Йошкар-Ола"
      target="_blank"
      rel="noopener noreferrer"
      class="text-primary-dark hover:text-primary underline font-heading text-lg transition-colors"
    >
      <span class="inline-flex items-center gap-1.5"><MapPinIcon client:visible size={20} /> Открыть в Яндекс.Картах</span>
    </a>
  </div>
</section>
