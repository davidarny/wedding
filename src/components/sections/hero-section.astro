---
import SectionHeading from '../ui/section-heading.astro';
import DecorativeDots from '../ui/decorative-dots.astro';
import FloralFrame from '../ui/floral-frame.astro';
---

<section id="hero" class="bg-white">
  <FloralFrame image="/images/floral-hero-frame.png" position="top">
    <div class="min-h-svh flex flex-col items-center justify-end pb-24 md:pb-32 px-6 text-center">
      <DecorativeDots />
      <p class="uppercase tracking-widest text-sm text-text-muted mb-4 font-body">ВМЕСТЕ И НАВСЕГДА</p>
      <SectionHeading as="h1" size="lg" className="mb-8">Даниил & Анастасия</SectionHeading>
    </div>
  </FloralFrame>
</section>