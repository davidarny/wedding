<section id="couple-profiles" class="py-10 md:py-16 px-4 bg-white/80">
  <div class="max-w-5xl mx-auto">
    <div class="flex flex-col md:flex-row justify-center items-center gap-12 md:gap-24">
      
      <!-- Groom Card -->
      <div class="text-center flex flex-col items-center">
        <div class="relative">
          <img 
            src="/images/photos/danil.webp" 
            alt="Даниил" 
            class="w-48 h-48 md:w-56 md:h-56 rounded-full object-cover mx-auto shadow-lg border-4 border-white"
            width={224}
            height={337}
            loading="lazy"
            decoding="async"
          />
        </div>
        <p class="font-cursive font-normal text-3xl mt-6 text-primary-dark">Даниил</p>
      </div>

      <!-- Bride Card -->
      <div class="text-center flex flex-col items-center">
        <div class="relative">
          <img 
            src="/images/photos/anastasia.webp" 
            alt="Анастасия" 
            class="w-48 h-48 md:w-56 md:h-56 rounded-full object-cover mx-auto shadow-lg border-4 border-white"
            width={224}
            height={337}
            loading="lazy"
            decoding="async"
          />
        </div>
        <p class="font-cursive font-normal text-3xl mt-6 text-primary-dark">Анастасия</p>
      </div>

    </div>
  </div>
</section>
