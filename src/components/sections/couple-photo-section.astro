---
import SectionWrapper from '../ui/section-wrapper.astro';
import FloralFrame from '../ui/floral-frame.astro';
---

<FloralFrame image="/images/floral-corner-frame.png" position="corners">
  <SectionWrapper id="couple-photo" noPadding className="px-6 py-20 md:px-8 md:py-32">
    <img 
      src="/images/photos/couple-placeholder.svg" 
      alt="Даниил и Анастасия" 
      class="max-w-sm w-full mx-auto rounded-lg shadow-lg"
    />
  </SectionWrapper>
</FloralFrame>