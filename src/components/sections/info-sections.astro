---
import SectionHeading from '../ui/section-heading.astro';
import FloralFrame from '../ui/floral-frame.astro';
---

<section id="info" class="bg-bg-soft">
  <FloralFrame image="/images/floral-corner-frame.png" position="corners" className="w-full h-full">
    <div class="container mx-auto px-4 py-12 md:py-24">
      
      <!-- Block 1 — Меню -->
      <div class="py-12 md:py-16">
        <SectionHeading cursive size="md" className="mb-6">Меню</SectionHeading>
        <p class="font-body text-lg leading-relaxed text-center max-w-md mx-auto text-text">
          Меню разнообразно, поэтому сообщите нам заранее, если у вас есть какие-либо предпочтения или диетические ограничения. После подтверждения вы сможете пройти опрос о своих вкусовых предпочтениях и напитках.
        </p>
      </div>

      <!-- Block 2 — Пожелания по подаркам -->
      <div class="py-12 md:py-16">
        <SectionHeading cursive size="md" className="mb-6">Пожелания по подаркам</SectionHeading>
        <p class="font-body text-lg leading-relaxed text-center max-w-md mx-auto text-text">
          Ваше присутствие в день нашей свадьбы - самый значимый подарок для нас!
        </p>
        <p class="font-body text-lg leading-relaxed text-center max-w-md mx-auto text-text mt-4">
          Мы понимаем, что дарить цветы на свадьбу - это традиция, но мы не сможем насладиться их красотой в полной мере... Будем рады любой другой альтернативе (вино или в денежном эквиваленте).
        </p>
      </div>

      <!-- Block 3 — Примечание -->
      <div class="py-12 md:py-16">
        <SectionHeading cursive size="md" className="mb-6">Примечание</SectionHeading>
        <p class="font-body text-lg leading-relaxed text-center max-w-md mx-auto text-text">
          Будем благодарны, если вы воздержитесь от криков "Горько" на празднике, ведь поцелуй — это знак выражения чувств, он не может быть по заказу.
        </p>
      </div>

      <!-- Block 4 — Подтверждение -->
      <div class="py-12 md:py-16">
        <SectionHeading cursive size="md" className="mb-6">Подтверждение</SectionHeading>
        <p class="font-body text-lg leading-relaxed text-center max-w-md mx-auto text-text">
          Пожалуйста подтвердите свое присутствие до 01.01.2025
        </p>
      </div>

      <!-- Block 5 — Фото -->
      <div class="py-12 md:py-16">
        <SectionHeading cursive size="md" className="mb-6">Фото</SectionHeading>
        <p class="font-body text-lg leading-relaxed text-center max-w-md mx-auto text-text">
          Опубликуйте фото дня нашей свадьбы в соц.сетях с хештегом #
        </p>
      </div>

    </div>
  </FloralFrame>
</section>
