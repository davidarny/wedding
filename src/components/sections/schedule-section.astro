---
const events = [
  {
    time: "13:00",
    date: "06.06.2026",
    title: "Торжественная регистрация брака",
    venue: "ЗАГС п. Оршанка, ул. Советская д. 109",
    description:
      "Наша регистрация пройдет в зале ЗАГСа поселка Оршанка, приглашаем всех разделить с нами такой торжественный момент",
  },
  {
    time: "15:00",
    date: "06.06.2026",
    title: "Фуршет",
    venue: "Банкетный зал",
    description: "Время пролетит незаметно за фуршетом и общением с другими гостями",
  },
  {
    time: "15:30",
    date: "06.06.2026",
    title: "Праздничный банкет",
    venue: "ресторан Savory House. г.Йошкар-Ола, ул. 70-летия Вооруженных сил СССР, д.20",
    description: "Здесь пройдет наш праздничный банкет",
  },
];
---

<section id="schedule" class="w-full">
  <!-- Part 1: Header Block -->
  <div class="bg-primary-dark relative overflow-hidden py-16 md:py-24">
    <!-- Floral overlay -->
    <img 
      src="/images/floral-top-border.png" 
      alt="" 
      class="absolute top-0 left-0 w-full h-auto opacity-30 pointer-events-none select-none z-0"
      aria-hidden="true"
    />
    
    <div class="relative z-10 container mx-auto px-4">
      <h2 class="text-white text-4xl md:text-5xl font-heading font-bold text-center text-balance">
        Свадебное расписание
      </h2>
    </div>
  </div>

  <!-- Part 2: Timeline -->
  <div class="bg-white py-16 md:py-24">
    <div class="container mx-auto px-4 max-w-3xl">
      <div class="flex flex-col">
        {events.map((event, index) => (
          <div class={`flex flex-col md:flex-row gap-4 md:gap-8 ${index !== events.length - 1 ? 'border-b border-primary-light/30 pb-8 mb-8' : ''}`}>
            <!-- Left side: Time & Date -->
            <div class="md:w-1/4 flex flex-col md:text-right md:pt-1 shrink-0">
              <span class="text-accent font-bold text-lg">{event.time}</span>
              <span class="text-text-muted text-sm">{event.date}</span>
            </div>
            
            <!-- Right side: Details -->
            <div class="md:w-3/4 flex flex-col">
              <h3 class="font-heading font-bold text-xl text-balance">{event.title}</h3>
              <span class="text-text-muted text-base mt-1">{event.venue}</span>
              <p class="text-text-muted text-sm mt-2 leading-relaxed text-pretty">
                {event.description}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
