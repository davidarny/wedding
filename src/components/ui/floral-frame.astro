---
interface Props {
  image: string;
  position: 'top' | 'full' | 'corners' | 'bottom';
  className?: string;
}

const { image, position, className = '' } = Astro.props;

const positionClasses = {
  top: 'top-0 left-0 right-0 w-full h-auto',
  full: 'inset-0 w-full h-full object-contain',
  corners: 'top-0 left-0 w-full h-full object-cover',
  bottom: 'bottom-0 left-0 right-0 w-full h-auto',
};
---

<div class={`relative overflow-hidden ${className}`}>
  <img
    src={image}
    alt=""
    class={`absolute pointer-events-none select-none z-0 ${positionClasses[position]}`}
    aria-hidden="true"
  />
  <div class="relative z-10">
    <slot />
  </div>
</div>
