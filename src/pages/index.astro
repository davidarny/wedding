---
import BaseLayout from "../layouts/base-layout.astro";
import LandingPage from "../components/landing-page.astro";
---

<BaseLayout>
  <div class="md:hidden">
    <LandingPage />
  </div>

  <div class="desktop-stage hidden md:flex">
    <div class="mobile-shell">
      <div class="mobile-shell__screen">
        <iframe
          id="embedded-frame"
          src="/embedded"
          title="Мобильная версия приглашения"
          class="mobile-shell__frame"
          loading="eager"
        ></iframe>
      </div>
      <img src="/images/frame.webp" alt="" class="mobile-shell__device-frame" loading="lazy" />
    </div>
  </div>
</BaseLayout>

<script>
  const search = window.location.search;
  if (search) {
    const frame = document.getElementById("embedded-frame");
    if (frame) {
      frame.src = `/embedded${search}`;
    }
  }
</script>

<style>
  @media (min-width: 768px) {
    :global(body) {
      overflow: hidden;
      background:
        linear-gradient(rgba(247, 247, 242, 0.9), rgba(247, 247, 242, 0.9)),
        url("/images/floral-tile-pattern.webp") repeat center / 360px;
    }

    .desktop-stage {
      min-height: 100svh;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }

    .mobile-shell {
      position: relative;
      height: min(900px, calc(100svh - 4rem));
      width: auto;
      max-width: min(100%, 430px);
      aspect-ratio: 389 / 800;
      filter: drop-shadow(0 20px 60px rgba(45, 45, 45, 0.18)) drop-shadow(0 6px 18px rgba(45, 45, 45, 0.1));
    }

    .mobile-shell__device-frame {
      position: relative;
      z-index: 2;
      display: block;
      width: 100%;
      height: auto;
      pointer-events: none;
      user-select: none;
    }

    .mobile-shell__screen {
      position: absolute;
      z-index: 1;
      inset: 1.4% 3.2% 3.3%;
      overflow: hidden;
      border-radius: 3.25rem;
      background: white;
    }

    .mobile-shell__frame {
      width: 100%;
      height: 100%;
      border: 0;
      display: block;
      background: white;
    }
  }
</style>
